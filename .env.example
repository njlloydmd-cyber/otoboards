# Get your key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional — only needed for the shared Question Bank feature. See README.md "Setting up the
# Question Bank" for how to generate this. Everything else works fine without it.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Optional — only needed for cross-device sync (Google sign-in). These four are PUBLIC values,
# safe to commit/expose (unlike the key above) — they identify your Firebase project to the
# browser, they don't grant any access by themselves. See README.md "Setting up cross-device
# sync" for where to find them. Leave all four blank if you don't want this feature.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
